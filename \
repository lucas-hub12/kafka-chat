from kafka import KafkaProducer

producer = KafkaProducer(bootstrap_servers='3.34.3.97:9092')

for i in range(10000):
    msg = f'message {i}'.encode('utf-8')
    producer.send('test-topic',msg)
    # producer.flush()
    # 100 개 단위로 나눠서 flush()하기
    if i % 100 == 0:
        producer.flush()
producer.flush()
